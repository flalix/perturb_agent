    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pubmed</bp:db>
    <bp:year rdf:datatype="http://www.w3.org/2001/XMLSchema#int">2002</bp:year>
    <bp:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biglycan organizes collagen VI into hexagonal-like networks resembling tissue structures</bp:title>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wiberg, C</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heinegård, D</bp:author>
