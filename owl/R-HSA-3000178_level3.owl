    <bp:right rdf:resource="#Complex52" />
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBSP binds collagen type I</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bone sialoprotein 2 binds collagen type I</bp:name>
    <bp:xref rdf:resource="#UnificationXref489" />
    <bp:xref rdf:resource="#UnificationXref490" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bone sialoprotein 2 (IBSP) is an anionic phosphorylated glycoprotein expressed almost exclusively in mineralized tissues. It is a potent nucleator of hydroxyapatite formation. The binding of IBSP to collagen is thought to be important for the initiation of bone mineralization and in the adhesion of bone cells to the mineralized matrix (Fujisawa et al. 1995, Tye et al. 2005).</bp:comment>
    <bp:xref rdf:resource="#PublicationXref152" />
    <bp:xref rdf:resource="#PublicationXref153" />
    <bp:dataSource rdf:resource="#Provenance1" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Authored: Jupe, S, 2012-08-08</bp:comment>
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reviewed: Ricard-Blum, Sylvie, 2013-08-13</bp:comment>
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Edited: Jupe, S, 2013-08-13</bp:comment>
  </bp:BiochemicalReaction>
