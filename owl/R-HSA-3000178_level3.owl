  <bp:Protein rdf:ID="Protein78">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITGB6</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Integrin beta-6</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary2" />
    <bp:entityReference rdf:resource="#ProteinReference35" />
    <bp:feature rdf:resource="#FragmentFeature71" />
