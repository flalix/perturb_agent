  <bp:Protein rdf:ID="Protein65">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LAMA1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Laminin alpha-1 chain</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference23" />
    <bp:feature rdf:resource="#FragmentFeature59" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 215953</bp:comment>
    <bp:xref rdf:resource="#UnificationXref249" />
