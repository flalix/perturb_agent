  <bp:Protein rdf:ID="Protein110">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TNX</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TNXB</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tenascin-X</bp:name>
