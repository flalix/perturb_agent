  <bp:PublicationXref rdf:ID="PublicationXref121">
    <bp:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">12882316</bp:id>
    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pubmed</bp:db>
    <bp:year rdf:datatype="http://www.w3.org/2001/XMLSchema#int">2003</bp:year>
    <bp:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Severe cognitive and motor coordination deficits in tenascin-R-deficient mice</bp:title>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Montag-Sallaz, M</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Montag, D</bp:author>
