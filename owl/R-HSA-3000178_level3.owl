  <bp:Protein rdf:ID="Protein111">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TNN</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tenascin-W</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tenascin-N</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TENN_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference47" />
    <bp:feature rdf:resource="#FragmentFeature100" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 2672030</bp:comment>
