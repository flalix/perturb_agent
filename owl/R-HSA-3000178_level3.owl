  <bp:Protein rdf:ID="Protein62">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AGRN</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AGRN(30-2045)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agrin</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AGRIN_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference20" />
    <bp:feature rdf:resource="#FragmentFeature56" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 375056</bp:comment>
    <bp:xref rdf:resource="#UnificationXref230" />
    <bp:xref rdf:resource="#UnificationXref231" />
