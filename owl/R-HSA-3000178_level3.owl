  <bp:Protein rdf:ID="Protein10">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ASPN</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Asporin</bp:name>
