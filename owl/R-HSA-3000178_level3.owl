  <bp:Protein rdf:ID="Protein77">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TNC</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tenascin</bp:name>
