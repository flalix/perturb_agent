    <bp:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The changes in glycosylation after partial hepatectomy enhance collagen binding of vitronectin in plasma</bp:title>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Uchibori-Iwaki, H</bp:author>
