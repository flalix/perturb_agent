  <bp:Protein rdf:ID="Protein70">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LAMA3</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Laminin alpha-3</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference28" />
    <bp:feature rdf:resource="#FragmentFeature64" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 445991</bp:comment>
    <bp:xref rdf:resource="#UnificationXref272" />
    <bp:xref rdf:resource="#UnificationXref273" />
