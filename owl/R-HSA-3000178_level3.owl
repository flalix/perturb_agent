  <bp:Protein rdf:ID="Protein81">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITGA8(39-1063)</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Integrin alpha-8</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary2" />
    <bp:entityReference rdf:resource="#ProteinReference38" />
    <bp:feature rdf:resource="#FragmentFeature74" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 215943</bp:comment>
    <bp:xref rdf:resource="#UnificationXref350" />
    <bp:xref rdf:resource="#UnificationXref351" />
    <bp:dataSource rdf:resource="#Provenance1" />
