  <bp:BiochemicalReaction rdf:ID="BiochemicalReaction3">
    <bp:conversionDirection rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LEFT-TO-RIGHT</bp:conversionDirection>
    <bp:left rdf:resource="#Protein11" />
    <bp:left rdf:resource="#PhysicalEntity6" />
    <bp:right rdf:resource="#Complex4" />
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BGN binds Collagen types I, VI, (IX)</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biglycan binds Collagen types I, VI, (IX)</bp:name>
    <bp:xref rdf:resource="#UnificationXref156" />
    <bp:xref rdf:resource="#UnificationXref157" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biglycan is a member of the small leucine-rich repeat proteoglycan family (SLRPs) which also includes decorin, fibromodulin (Hedlund et al. 1994 - binding to collagen II), lumican and asporin (Hedbom &amp; Heinegard 1993, Ezura et al. 2000). All appear to be involved in collagen fibril formation and matrix assembly (Ameye &amp; Young 2002).  &lt;br&gt;&lt;br&gt;Biglycan binds collagen types I (Schönherr et al. 1995), II (Bovine, using pig byglycan - Vynios et al. 2001, Bovine, using bovine biglycan - Douglas et al. 2008), III (Bovine, using bovine biglycan - Douglas et al. 2008), VI (Wiberg et al. 2001, 2002, human) and IX (Chen et al. 2006 -  species source of collagen/biglycan unknown).</bp:comment>
    <bp:xref rdf:resource="#PublicationXref36" />
    <bp:xref rdf:resource="#PublicationXref37" />
    <bp:xref rdf:resource="#PublicationXref38" />
    <bp:xref rdf:resource="#PublicationXref39" />
    <bp:xref rdf:resource="#PublicationXref40" />
    <bp:xref rdf:resource="#PublicationXref41" />
    <bp:dataSource rdf:resource="#Provenance1" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Authored: Jupe, S, 2013-01-10</bp:comment>
