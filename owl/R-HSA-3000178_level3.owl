  <bp:PublicationXref rdf:ID="PublicationXref58">
    <bp:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">12808446</bp:id>
    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pubmed</bp:db>
    <bp:year rdf:datatype="http://www.w3.org/2001/XMLSchema#int">2003</bp:year>
    <bp:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">How vitronectin binds PAI-1 to modulate fibrinolysis and cell migration</bp:title>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Zhou, A</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Huntington, JA</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pannu, Navraj S</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carrell, RW</bp:author>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Read, Randy J</bp:author>
