  <bp:Protein rdf:ID="Protein72">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LAMA5</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Laminin alpha-5 chain</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference30" />
    <bp:feature rdf:resource="#FragmentFeature66" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 215956</bp:comment>
    <bp:xref rdf:resource="#UnificationXref286" />
