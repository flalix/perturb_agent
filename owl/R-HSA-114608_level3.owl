  <bp:Protein rdf:ID="Protein43">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">F8</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Coagulation factor VIII precursor</bp:name>
