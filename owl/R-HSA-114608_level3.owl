  <bp:Protein rdf:ID="Protein260">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PFN1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Profilin I</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference120" />
    <bp:feature rdf:resource="#FragmentFeature245" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 203081</bp:comment>
    <bp:xref rdf:resource="#UnificationXref764" />
