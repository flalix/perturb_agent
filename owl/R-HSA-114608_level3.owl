  <bp:ProteinReference rdf:ID="ProteinReference118">
    <bp:organism rdf:resource="#BioSource1" />
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UniProt:Q01518 CAP1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CAP1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CAP</bp:name>
    <bp:xref rdf:resource="#UnificationXref757" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">FUNCTION Directly regulates filament dynamics and has been implicated in a number of complex developmental and morphological processes, including mRNA localization and the establishment of cell polarity.SUBUNIT Homodimer. Binds actin monomers.SIMILARITY Belongs to the CAP family.</bp:comment>
  </bp:ProteinReference>
