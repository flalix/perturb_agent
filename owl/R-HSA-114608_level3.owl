  <bp:Protein rdf:ID="Protein70">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGFA-1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGFA isoform 1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Platelet-derived growth factor, A chain isoform 1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGF A-chain</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Platelet-derived growth factor alpha polypeptide</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference46" />
    <bp:feature rdf:resource="#FragmentFeature67" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 184205</bp:comment>
