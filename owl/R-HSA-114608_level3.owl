  <bp:Protein rdf:ID="Protein270">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SCG3</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Secretogranin-3 precursor</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary8" />
    <bp:entityReference rdf:resource="#ProteinReference124" />
    <bp:feature rdf:resource="#FragmentFeature253" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 350730</bp:comment>
