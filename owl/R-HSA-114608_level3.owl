  <bp:Protein rdf:ID="Protein104">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">APOOL</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MICOS complex subunit MIC27</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MIC27_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference75" />
    <bp:feature rdf:resource="#FragmentFeature97" />
