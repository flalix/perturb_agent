  <bp:Protein rdf:ID="Protein103">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QSOX1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sulfhydryl oxidase 1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QSOX1_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference74" />
    <bp:feature rdf:resource="#FragmentFeature96" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 8848890</bp:comment>
    <bp:xref rdf:resource="#UnificationXref372" />
    <bp:xref rdf:resource="#UnificationXref373" />
