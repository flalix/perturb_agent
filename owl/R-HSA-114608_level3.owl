  <bp:Protein rdf:ID="Protein115">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VTI1B</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vesicle transport through interaction with t-SNAREs homolog 1B</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VTI1B_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference86" />
    <bp:feature rdf:resource="#FragmentFeature108" />
