  <bp:Protein rdf:ID="Protein53">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PAI</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SERPINE1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plasminogen activator inhibitor-1 precursor</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PAI-1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endothelial plasminogen activator inhibitor</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference32" />
    <bp:feature rdf:resource="#FragmentFeature51" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 114649</bp:comment>
    <bp:xref rdf:resource="#UnificationXref217" />
    <bp:xref rdf:resource="#UnificationXref218" />
