  <bp:Protein rdf:ID="Protein268">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TF</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Serotransferrin</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary8" />
    <bp:entityReference rdf:resource="#ProteinReference122" />
    <bp:feature rdf:resource="#FragmentFeature251" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 350704</bp:comment>
