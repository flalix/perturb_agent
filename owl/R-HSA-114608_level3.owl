  <bp:Protein rdf:ID="Protein79">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">FIGF</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VEGFD</bp:name>
