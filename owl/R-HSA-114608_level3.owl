  <bp:Protein rdf:ID="Protein195">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD9</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD9 antigen</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">P24</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Leukocyte antigen MIC3</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Motility-related protein</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRP-1</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary7" />
    <bp:entityReference rdf:resource="#ProteinReference90" />
    <bp:feature rdf:resource="#FragmentFeature183" />
