  <bp:Protein rdf:ID="Protein230">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACTK</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POTEKP</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kappa-actin</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference109" />
    <bp:feature rdf:resource="#FragmentFeature217" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 350756</bp:comment>
    <bp:xref rdf:resource="#UnificationXref691" />
