  <bp:Protein rdf:ID="Protein74">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pro-EGF</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EGF(23-1207)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pro-epidermal growth factor precursor</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference48" />
    <bp:feature rdf:resource="#FragmentFeature70" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 139875</bp:comment>
    <bp:xref rdf:resource="#UnificationXref285" />
    <bp:xref rdf:resource="#UnificationXref286" />
