  <bp:ProteinReference rdf:ID="ProteinReference42">
    <bp:organism rdf:resource="#BioSource1" />
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UniProt:P00746 CFD</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CFD</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DF</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PFD</bp:name>
    <bp:xref rdf:resource="#UnificationXref250" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">FUNCTION Factor D cleaves factor B when the latter is complexed with factor C3b, activating the C3bbb complex, which then becomes the C3 convertase of the alternate pathway. Its function is homologous to that of C1s in the classical pathway.SIMILARITY Belongs to the peptidase S1 family.</bp:comment>
  </bp:ProteinReference>
