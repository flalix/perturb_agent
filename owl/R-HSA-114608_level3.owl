  <bp:Protein rdf:ID="Protein32">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD63</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD63 antigen</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Melanoma-associated antigen ME491</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lysosome-associated membrane glycoprotein 3</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LAMP-3</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ocular melanoma-associated antigen</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OMA81H</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Granulophysin</bp:name>
