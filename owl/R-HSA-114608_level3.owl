  <bp:Protein rdf:ID="Protein95">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IGF1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insulin-like growth factor 1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Somatomedin C</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference66" />
    <bp:feature rdf:resource="#FragmentFeature88" />
