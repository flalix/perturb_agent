  <bp:Protein rdf:ID="Protein88">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TIMP1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metalloproteinase inhibitor 1</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
