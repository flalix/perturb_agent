  <bp:Protein rdf:ID="Protein92">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GAS6</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GAS6(39-691)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">growth-arrest-specific protein 6</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference64" />
