  <bp:Protein rdf:ID="Protein41">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PPBP</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PPBP(35-128)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Beta-thromboglobulin</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference21" />
    <bp:feature rdf:resource="#FragmentFeature39" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 114572</bp:comment>
