    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vascular endothelial growth factor C precursor</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vascular endothelial growth factor related protein</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Flt4 ligand</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Flt4- L</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference51" />
    <bp:feature rdf:resource="#FragmentFeature73" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 67159</bp:comment>
    <bp:xref rdf:resource="#UnificationXref294" />
