  <bp:Protein rdf:ID="Protein56">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TGF-beta 1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TGFB1(30-278)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transforming growth factor beta 1 precursor</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference33" />
