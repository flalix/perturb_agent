  <bp:Protein rdf:ID="Protein277">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BiP</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HSPA5</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">78 kDa glucose-regulated protein</bp:name>
