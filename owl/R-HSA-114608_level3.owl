  <bp:Protein rdf:ID="Protein91">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ALDOA</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fructose-bisphosphate aldolase A</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Muscle-type aldolase</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lung cancer antigen NY-LU-1</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference63" />
    <bp:feature rdf:resource="#FragmentFeature85" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 349738</bp:comment>
    <bp:xref rdf:resource="#UnificationXref335" />
    <bp:xref rdf:resource="#UnificationXref336" />
