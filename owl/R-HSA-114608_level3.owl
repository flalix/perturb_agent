  <bp:Protein rdf:ID="Protein100">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ORM1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alpha-1-acid glycoprotein 1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A1AG1_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference71" />
    <bp:feature rdf:resource="#FragmentFeature93" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 8848906</bp:comment>
    <bp:xref rdf:resource="#UnificationXref363" />
