  <bp:Protein rdf:ID="Protein87">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">F13A1(1-731)</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">factor XIII A chain</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference59" />
    <bp:feature rdf:resource="#FragmentFeature81" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 349759</bp:comment>
    <bp:xref rdf:resource="#UnificationXref322" />
    <bp:xref rdf:resource="#UnificationXref323" />
