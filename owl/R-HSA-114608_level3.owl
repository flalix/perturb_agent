  <bp:Protein rdf:ID="Protein90">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TMSB4X</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thymosin beta-4</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference62" />
    <bp:feature rdf:resource="#FragmentFeature84" />
