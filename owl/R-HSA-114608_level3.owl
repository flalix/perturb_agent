  <bp:Protein rdf:ID="Protein228">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BRPF3</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bromodomain and PHD finger-containing protein 3</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary1" />
    <bp:entityReference rdf:resource="#ProteinReference107" />
    <bp:feature rdf:resource="#FragmentFeature215" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 350716</bp:comment>
