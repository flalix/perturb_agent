  <bp:CellularLocationVocabulary rdf:ID="CellularLocationVocabulary10">
    <bp:term rdf:datatype="http://www.w3.org/2001/XMLSchema#string">endoplasmic reticulum membrane</bp:term>
    <bp:xref rdf:resource="#UnificationXref813" />
  </bp:CellularLocationVocabulary>
  <bp:UnificationXref rdf:ID="UnificationXref813">
    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GENE ONTOLOGY</bp:db>
