  <bp:UnificationXref rdf:ID="UnificationXref821">
    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GENE ONTOLOGY</bp:db>
    <bp:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GO:0043202</bp:id>
