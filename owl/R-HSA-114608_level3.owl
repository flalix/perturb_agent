  <bp:Protein rdf:ID="Protein69">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C1Inh</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SERPING1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plasma protease C1 inhibitor precursor</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C1 Inh</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
