  <bp:ProteinReference rdf:ID="ProteinReference49">
    <bp:organism rdf:resource="#BioSource1" />
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UniProt:P49765 VEGFB</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VEGFB</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VRF</bp:name>
    <bp:xref rdf:resource="#UnificationXref287" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">FUNCTION Growth factor for endothelial cells. VEGF-B167 binds heparin and neuropilin-1 whereas the binding to neuropilin-1 of VEGF-B186 is regulated by proteolysis.SUBUNIT Homodimer; disulfide-linked. Can also form heterodimer with VEGF.TISSUE SPECIFICITY Expressed in all tissues except liver. Highest levels found in heart, skeletal muscle and pancreas.PTM VEGF-B186 is O-glycosylated.SIMILARITY Belongs to the PDGF/VEGF growth factor family.</bp:comment>
  </bp:ProteinReference>
