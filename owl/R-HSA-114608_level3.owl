  <bp:Protein rdf:ID="Protein71">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">c-sis</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGFB(21-81)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Platelet-derived growth factor, B chain</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGF B-chain</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Platelet-derived growth factor beta polypeptide</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PDGF-2</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Becaplermin</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference47" />
    <bp:feature rdf:resource="#FragmentFeature68" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 184200</bp:comment>
