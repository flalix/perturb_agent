  <bp:Protein rdf:ID="Protein99">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AHSG</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alpha-2-HS-glycoprotein</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">FETUA_HUMAN</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference70" />
    <bp:feature rdf:resource="#FragmentFeature92" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 8848910</bp:comment>
