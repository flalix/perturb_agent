  <bp:CellularLocationVocabulary rdf:ID="CellularLocationVocabulary8">
    <bp:term rdf:datatype="http://www.w3.org/2001/XMLSchema#string">secretory granule lumen</bp:term>
    <bp:xref rdf:resource="#UnificationXref783" />
