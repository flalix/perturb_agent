    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UniProt:Q9BWS9 CHID1</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CHID1</bp:name>
