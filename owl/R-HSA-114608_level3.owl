    <bp:db rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pubmed</bp:db>
    <bp:year rdf:datatype="http://www.w3.org/2001/XMLSchema#int">1996</bp:year>
    <bp:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The lysosomal granule membrane protein, LAMP-2, is also present in platelet dense granule membranes</bp:title>
    <bp:author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Israels, SJ</bp:author>
