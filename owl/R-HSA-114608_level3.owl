  <bp:Protein rdf:ID="Protein49">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multimerin 1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MMRN1(20-1228)</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference29" />
    <bp:feature rdf:resource="#FragmentFeature47" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 114634</bp:comment>
    <bp:xref rdf:resource="#UnificationXref206" />
    <bp:xref rdf:resource="#UnificationXref207" />
