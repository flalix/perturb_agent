  <bp:Protein rdf:ID="Protein64">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A2M</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alpha-2-macroglobulin</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alpha-2-M</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference41" />
    <bp:feature rdf:resource="#FragmentFeature61" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 139834</bp:comment>
    <bp:xref rdf:resource="#UnificationXref248" />
    <bp:xref rdf:resource="#UnificationXref249" />
