  <bp:Protein rdf:ID="Protein93">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">THBS1</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thrombospondin 1 precursor</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary6" />
    <bp:entityReference rdf:resource="#ProteinReference65" />
    <bp:feature rdf:resource="#FragmentFeature87" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 114701</bp:comment>
    <bp:xref rdf:resource="#UnificationXref341" />
