  <bp:Protein rdf:ID="Protein192">
    <bp:displayName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GPIIb</bp:displayName>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ITGA2B(32-?)</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Integrin alpha-IIb</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Platelet membrane glycoprotein IIb</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GPalpha IIb</bp:name>
    <bp:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD41 antigen</bp:name>
    <bp:cellularLocation rdf:resource="#CellularLocationVocabulary7" />
    <bp:entityReference rdf:resource="#ProteinReference87" />
    <bp:feature rdf:resource="#FragmentFeature180" />
    <bp:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactome DB_ID: 114511</bp:comment>
    <bp:xref rdf:resource="#UnificationXref584" />
